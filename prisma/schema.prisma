generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Produk {
  id        Int           @id @default(autoincrement())
  nama      String
  harga     Int
  kategori  String
  deskripsi String?
  gambar    String?
  stok      Int           @default(0)
  createdAt DateTime      @default(now())
  items     PesananItem[]
}

model User {
  id             Int              @id @default(autoincrement())
  nama           String
  email          String           @unique
  password       String
  role           String           @default("user")
  telepon        String?
  alamat         String?
  createdAt      DateTime         @default(now())
  pesanan        Pesanan[]
  resetPasswords ResetPassword[]
}

model Pesanan {
  id               Int           @id @default(autoincrement())
  userId           Int
  total            Int
  status           String        @default("pending")
  alamat           String?
  telepon          String?
  namaPenerima     String?
  buktiPembayaran  String?
  ongkir           Int           @default(0)
  kotaTujuan       String?
  createdAt        DateTime      @default(now())
  user             User          @relation(fields: [userId], references: [id])
  items            PesananItem[]
}

model PesananItem {
  id        Int     @id @default(autoincrement())
  pesananId Int
  produkId  Int
  jumlah    Int
  harga     Int
  pesanan   Pesanan @relation(fields: [pesananId], references: [id])
  produk    Produk  @relation(fields: [produkId], references: [id])
}

model OngkirKota {
  id        Int      @id @default(autoincrement())
  kota      String   @unique
  biaya     Int
  estimasi  String
  createdAt DateTime @default(now())
}

model ResetPassword {
  id        Int      @id @default(autoincrement())
  userId    Int
  kode      String
  expiredAt DateTime
  dipakai   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
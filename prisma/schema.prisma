generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Produk {
  id         Int            @id @default(autoincrement())
  nama       String
  harga      Int
  kategori   String
  deskripsi  String?
  gambar     String?
  stok       Int            @default(0)
  createdAt  DateTime       @default(now())
  items      PesananItem[]
  fotos      FotoProduk[]
  ukurans    UkuranProduk[]
}

model FotoProduk {
  id        Int      @id @default(autoincrement())
  produkId  Int
  url       String
  urutan    Int      @default(0)
  createdAt DateTime @default(now())
  produk    Produk   @relation(fields: [produkId], references: [id])
}

model User {
  id             Int              @id @default(autoincrement())
  nama           String
  email          String           @unique
  password       String
  role           String           @default("user")
  telepon        String?
  alamat         String?
  createdAt      DateTime         @default(now())
  pesanan        Pesanan[]
  resetPasswords ResetPassword[]
}

model Pesanan {
  id                Int           @id @default(autoincrement())
  userId            Int
  total             Int
  status            String        @default("pending")
  alamat            String?
  telepon           String?
  namaPenerima      String?
  buktiPembayaran   String?
  ongkir            Int           @default(0)
  kotaTujuan        String?
  kurir             String?
  metodePembayaran  String?
  paymentStatus     String        @default("unpaid")
  paymentOrderId    String?
  paymentNumber     String?
  paymentExpiredAt  DateTime?
  createdAt         DateTime      @default(now())
  user              User          @relation(fields: [userId], references: [id])
  items             PesananItem[]
}

model PesananItem {
  id        Int     @id @default(autoincrement())
  pesananId Int
  produkId  Int
  jumlah    Int
  harga     Int
  pesanan   Pesanan @relation(fields: [pesananId], references: [id])
  produk    Produk  @relation(fields: [produkId], references: [id])
}

model ZonaOngkir {
  id        Int      @id @default(autoincrement())
  namaZona  String
  wilayah   String
  biaya     Int
  estimasi  String
  createdAt DateTime @default(now())
}

model ResetPassword {
  id        Int      @id @default(autoincrement())
  userId    Int
  kode      String
  expiredAt DateTime
  dipakai   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model UkuranProduk {
  id        Int      @id @default(autoincrement())
  produkId  Int
  ukuran    String
  stok      Int      @default(0)
  createdAt DateTime @default(now())
  produk    Produk   @relation(fields: [produkId], references: [id])
}

model Voucher {
  id           Int      @id @default(autoincrement())
  kode         String   @unique
  diskon       Int
  tipe         String   @default("persen")
  minBelanja   Int      @default(0)
  maxDiskon    Int?
  kuota        Int      @default(1)
  terpakai     Int      @default(0)
  aktif        Boolean  @default(true)
  expiredAt    DateTime?
  createdAt    DateTime @default(now())
}